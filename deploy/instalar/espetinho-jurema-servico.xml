<service>
  <id>EspetinhoJurema</id>
  <name>Espetinho Jurema - Delivery</name>
  <description>Servidor local Espetinho Jurema (mesas, pedidos, caixa). Inicia com o Windows.</description>
  <executable>cmd</executable>
  <arguments>/c &quot;%BASE%\start-servico.bat&quot;</arguments>
  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-time">
    <pattern>yyyyMMdd</pattern>
  </log>
  <workingdirectory>%BASE%</workingdirectory>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
</service>
